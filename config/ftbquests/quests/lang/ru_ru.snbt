	quest.6A4CB4700F0082C6.quest_desc: [
		"Обучение &aзавершено&r."
		""
		"Чтобы увидеть остальные квесты, наведите курсор на левый край экрана и разверните &6группы глав&r."
		""
		"Если останутся вопросы, присоединяйтесь к нашему &bDiscord&r: https://discord.gg/5mJnYNMv6Q"
