	quest.672C61B048CB3B85.quest_desc: [
		"In order to make a train, you're going to need at least:"
		""
		"- 1 &6Train Casing&r"
		"- 1 &6Train Station&r"
		"- Enough &6Train Tracks&r to make your railroad"
		""
		"In order to see how you assemble a train, &b&lponder&r the &6Train Station&r"
	]
	quest.673368ABD9144D6D.quest_subtitle: "Perfect for building, and that's about it"
	quest.67B3D0A82F1BB3EA.quest_subtitle: "The basis for more advanced blocks"
	quest.67CE399D0A9C0F57.quest_subtitle: "&6Mechanical Crafters&r allow for both automatic crafting of normal recipes and the crafting of recipes that are larger than a normal crafting table would allow"
	quest.67E511B88ADFC5BC.title: "Activate the Sprinkler by using a Potions or Connecting Fluid tank"
	quest.6814CD8420D6DA66.quest_subtitle: "You heard it right lads, FE in Create. You'll probably need more than your normal waterwheels to power this thing."
	quest.6814CD8420D6DA66.title: "FE in create?"
	quest.68567D80BF886B45.quest_subtitle: "A &6Schedule&r lets you schedule trains so that mobs or &6Blaze Burners&r can drive them"
	quest.686C1705E2FEC061.quest_subtitle: "The Fishing Net is a contraption component designed to catch small aquatic animals while also allowing fishing at the same time."
	quest.686C1705E2FEC061.title: "Craft Fishing Net"
	quest.68AC478385F4DE6C.quest_subtitle: "Congratulations! You have obtained Super Experience, which can be used on the Blaze Forger or Enchanter to create more powerful enchantments."
	quest.68AC478385F4DE6C.title: "&bObtain Super Experience Block."
	quest.68CC0DF64AD608C1.quest_subtitle: "Generates twice as much &6SU&r as the regular &9Water Wheel&r but at a slower &6RPM&r. Just know that this is bigger and bulkier, so prepare a lot of space for it"
	quest.6933441D38037E5A.quest_subtitle: "All recipes from Farmer's Delight requiring the Cooking Pot are added as heated mixing recipes."
	quest.6933441D38037E5A.title: "Use Mechanical Mixer as an Automatic Cooking appliance"
	quest.6934E2BC749EB926.quest_subtitle: "90% of Create mods use Andesite Alloy, better stock up."
	quest.6934E2BC749EB926.title: "Obtain Andesite Alloy"
	quest.694D568E65C188C2.quest_subtitle: "Take some blaze cakes, it's going to heat up!"
	quest.694D568E65C188C2.title: "Metallurgy Expert"
	quest.69519BFDAAA790DE.quest_subtitle: "Set up a Blaze Burner, Mechanical Mixer, and Basin to create potions. Place a Mechanical Pipe near the Basin to drain the potions into a Fluid Tank."
	quest.69519BFDAAA790DE.title: "Set up Mechanical Mixer with Blaze Burner"
	quest.69711045D959224B.quest_subtitle: "Put Inactive Blaze Core into a Depot and activate the Deployer with Flint and Steel to fuel the Blaze core."
	quest.69711045D959224B.title: "Activate Deployer"
