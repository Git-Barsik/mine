	quest.74A663BECB035204.title: "Welcome to Create: Propulsion!"
	quest.74ADDF7066B30B3F.quest_subtitle: "An &6Encased Chain Drive&r allows for multiple parallel rotational outputs, and to change the axis of the rotational output once"
