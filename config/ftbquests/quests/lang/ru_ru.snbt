	quest.642172D58E8B11E1.quest_desc: ["You can also switch the look of your &6Water Wheel&r by right-clicking it with pretty much any &awood plank&r (including ones from other mods)"]
	quest.642172D58E8B11E1.quest_subtitle: "A kinetic source that uses the flow of &9water&r as its source of energy. It will generate the same amount of &6SU&r at the same &6RPM&r as long as one block of flowing &9water&r is adjacent"
	quest.648C13279144617F.title: "Better Solar"
	quest.64D485944845F231.title: "Obtain &6Stirling Engine"
	quest.64F520643E1E82C9.quest_subtitle: "A clutch that is only coupled if the input RPM is faster than a configurable threshold. Useful for vehicles when you have engines always on but don't want to always be moving."
	quest.64F520643E1E82C9.title: "Obtain Centrifugal Clutch"
	quest.65A2AC554D856D93.quest_subtitle: "A &6Gantry Carriage&r allows for contraptions that move across gantries. Multiple &6Gantry Carriages&r can be chained, allowing for muliple axes of movement"
	quest.65C171B1CD610846.quest_subtitle: "Used for Display and Beam Reader."
	quest.65D9E2BA22CC2DBC.title: "Obtain Copper Coil"
	quest.65EA25D2DDEE694F.quest_subtitle: "Slow but easy to maneuver"
	quest.666E9828756ADB0C.quest_desc: ["Can also be used to encase &6Fluid Pipes&r"]
	quest.666E9828756ADB0C.quest_subtitle: "The basis of most fluid-related things in &6&lCreate&r"
