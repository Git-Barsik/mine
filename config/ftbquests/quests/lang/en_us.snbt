	quest.021E30871E97C634.quest_subtitle: "A &6Mechanical Arm&r is an advanced item distribution machine that works by designating it to specific blocks the arm can reach. If it can't reach a location, the arm won't work. Requires &6SUs&r to operate"
	quest.02903C6F107C8DA0.quest_subtitle: "Finally, nuclear"
	quest.02C47B1CE17E8DD5.quest_subtitle: "Hand cranks with a cogwheel installed. Handy for gear ratios and tight spaces"
	quest.02C47B1CE17E8DD5.title: "Obtain Crank wheel"
	quest.02D5439ACE50EC34.quest_subtitle: "A better version, used as a fuel"
	quest.02D5439ACE50EC34.title: "Obtain Refined Coal Coke"
	quest.0306E0A1DA82A811.quest_subtitle: "A &cRedstone Contact&r component that outputs a signal when in contact with another &cRedstone Contact&r. Particularly useful for building contraptions"
	quest.0360911A620C6613.title: "Obtain Rose Quartz Catalyst Coil"
	quest.03795968E7FA18BA.quest_desc: [
		"Place it. &eRight-click&r"
		"You can now see every shop on the server, price history, trends, and the most active traders"
		""
		"The mod scans the world for &6Table Cloth&r and &6Tradeworks Shelves&r and turns them into a live market interface similar to a stock exchange with the &6Market Terminal&r block"
	]
	quest.03795968E7FA18BA.quest_subtitle: "&6&lCreate: Stock Market&r turns your server economy into a live, player-driven stock exchange"
	quest.03CD30560CC82ACC.quest_subtitle: "-20% Engine power -75% fuel requirement, for those long haul trips on the cheap"
	quest.03FAA1891E7D56FD.quest_subtitle: "A &6Smart Chute&r is a more configurable chute that also allows full item stacks to be moved"
	quest.046435AD378CE0C8.quest_subtitle: "Best of the best magnets in store, but extremely expensive"
	quest.04CEE0CA932DF671.quest_subtitle: "This Create addon adds a variety of items and recipes, introducing new fuel sources for Blaze Burners and giving players unique ways to build Steam Boiler setups. Ever wanted a renewable alternative to Blaze Cakes? Now you have one!"
	quest.04CEE0CA932DF671.title: "&2Welcome to Blaze Burner Fuels"
